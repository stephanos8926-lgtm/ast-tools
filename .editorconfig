# EditorConfig: consistent coding styles across editors and IDEs
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.py]
# Ruff formatter handles Python formatting;
# indent_size here sets baseline for editors.
indent_size = 4